{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@modules/(.*)$": "<rootDir>/../src/modules/$1",
    "^@user/(.*)$": "<rootDir>/../src/modules/user/$1",
    "^@shared/(.*)$": "<rootDir>/../src/shared/$1"
  },
  "setupFiles": ["<rootDir>/setup-env.js"]
}
